# Copia in .env.local per sviluppo locale.
# In produzione (Hostinger): imposta le variabili nella dashboard, NON committare .env.
# Il backend (API routes) legge con process.env; il frontend React non vede queste variabili.

# Database MySQL (stesso DB del vecchio sito PHP)
# Su Hostinger usa 127.0.0.1 (non localhost) per evitare "Access denied ... @'::1'"
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=u589701076_salute
DB_USER=u589701076_usersalute
DB_PASSWORD=la_tua_password
DB_CHARSET=utf8mb4

# ID progetto C.A.S.A nella tabella projects (usato solo dal server per tracking)
PROJECT_ID=6

# Tracking: backend dedicato api.casanziani.com (consigliato – zero DB/env su Node per il tracking)
# Imposta l'URL base dell'API (senza slash finale). Il frontend invierà le richieste qui.
NEXT_PUBLIC_TRACKING_API_URL=https://api.casanziani.com

# Alternativa: stesso dominio con PHP (solo se NON usi api.casanziani.com)
# NEXT_PUBLIC_USE_PHP_TRACKING=1
